{
  "name": "kolabs-desktop",
  "version": "1.0.0",
  "description": "Kolabs Sample Management desktop app (Electron + Python sidecar)",
  "main": "main.cjs",
  "author": "Kolabs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kolabs.samplemanagement",
    "productName": "Kolabs Sample Management",
    "afterPack": "afterPack.cjs",
    "files": ["main.cjs"],
    "extraResources": [
      { "from": "../backend/dist/kolabs-backend", "to": "backend" }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    }
  }
}
