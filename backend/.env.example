# Where uploaded original files + parsed-cache sidecars are stored.
# On Railway/Fly/Render, point this at a mounted persistent volume.
UPLOAD_DIR=/data/uploads

# SQLite metadata DB. Put it on the persistent volume too.
DB_URL=sqlite:////data/app.db

# Max upload size in bytes (default 50MB).
MAX_FILE_BYTES=52428800

# Only needed if the SPA is served from a different origin than the API.
# CORS_ORIGINS=https://app.example.com
